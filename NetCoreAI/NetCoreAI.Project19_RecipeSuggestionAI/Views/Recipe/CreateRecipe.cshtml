@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yemek Tarifi Öner</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
            body {
                background: #F8F6F4;
                font-family: 'Poppins', sans-serif;
            }

            .container {
                max-width: 600px;
                margin-top: 50px;
                padding: 30px;
                background: white;
                border-radius: 15px;
                box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
            }

            h2 {
                text-align: center;
                color: #5C5470;
                font-weight: 700;
            }

            .form-label {
                font-weight: 600;
                color: #5C5470;
            }

            .btn-primary {
                background: #A084CA;
                border: none;
                font-weight: 600;
                padding: 10px 15px;
                border-radius: 10px;
            }

                .btn-primary:hover {
                    background: #8466A1;
                }

            .alert {
                margin-top: 15px;
            }

            .result-box {
                background: #E8DFF5;
                padding: 20px;
                border-radius: 10px;
                margin-top: 20px;
                color: #5C5470;
                font-size: 16px;
                font-weight: 500;
            }
    </style>
</head>
<body>
    <div class="container py-5" style="max-width: 640px;">
        <h1 class="text-primary text-center mb-1">
            <span aria-hidden="true">🍽</span> AI Yemek Tarifi
        </h1>
        <p class="text-center text-secondary fw-semibold mb-4">
            Elindeki malzemeleri gir, yapabileceğin yemekleri öğren!
        </p>

        <form method="post" class="bg-white p-4 rounded-4 shadow-sm border">
            <label for="ingredients" class="form-label text-dark fw-semibold">
                Malzemelerinizi Giriniz <strong class="text-primary">(virgüllerle ayırınız.)</strong>
            </label>
            <input type="text"
                   id="ingredients"
                   name="ingredients"
                   class="form-control form-control-lg shadow-none border-2"
                   placeholder="Örn: Domates, Biber, Soğan, Peynir, Makarna..."
                   required />
            <div class="mt-3">
                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold fs-5">
                    <span aria-hidden="true">🍲</span> Tarif Öner
                </button>
            </div>
        </form>
        <div class="result-box">
            <h4><span aria-hidden="true">🍲</span> Tarif</h4>
            <p style="white-space: pre-line; line-height: 2;">@ViewBag.recipe</p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>


